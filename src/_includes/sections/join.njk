<section class="section-band section-band-accent" id="join">
  <div class="section-heading">
    <p class="eyebrow">Join / collaborate</p>
    <h2>{{ site.joinTitle }}</h2>
    <p>{{ site.joinSummary }}</p>
  </div>
  <div class="join-grid">
    <div class="join-copy">
      <p>{{ site.joinDetail }}</p>
      <p>{{ site.joinCtaText }}</p>
      <a class="button button-primary" href="mailto:{{ site.contactEmail }}">{{ site.joinCtaLabel }}</a>
    </div>
  </div>
</section>
