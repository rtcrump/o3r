{% set featured = team | selectattr("featured") | list %}
{% set members = team | rejectattr("featured") | list %}
<section class="section-band section-band-deep" id="team">
  <div class="section-heading">
    <p class="eyebrow">Team</p>
    <h2>Our team</h2>
    <p>O3R is a virtual-first research group connecting students, clinicians, and collaborators around practical ocular oncology problems.</p>
  </div>

  <div class="pi-grid">
    {% for person in featured %}
      <article class="pi-card">
        <div class="initials-badge">{% initials person.name %}</div>
        <div class="pi-copy">
          <p class="role-label">{{ person.role }}</p>
          <h3>{{ person.name }}</h3>
          <p>{{ person.summary or site.piSummary }}</p>
          {% if person.scholarUrl or person.orcidUrl %}
            <div class="metadata-group">
              <p class="meta-label">Profiles</p>
              <p class="person-links">
                {% if person.scholarUrl %}<a href="{{ person.scholarUrl }}">Google Scholar</a>{% endif %}
                {% if person.orcidUrl %}<a href="{{ person.orcidUrl }}">ORCID</a>{% endif %}
              </p>
            </div>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>

  <div class="team-grid">
    {% for member in members %}
      <article class="team-card">
        <div class="team-card-top">
          <div class="initials-badge">{% initials member.name %}</div>
          <div>
            <h3>{{ member.name }}</h3>
            <p class="role-label">{{ member.role }}</p>
          </div>
        </div>
        {% set memberProjects = member.projects | findProject(projects) %}
        {% if memberProjects.length %}
          <div class="metadata-group">
            <p class="meta-label">Projects</p>
            <ul class="chip-list member-projects">
              {% for project in memberProjects %}
                <li><a class="project-chip" href="#project-{{ project.id }}">{{ project.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% else %}
          <p class="team-note">Project assignments can be added here when ready.</p>
        {% endif %}
        {% if member.scholarUrl or member.orcidUrl %}
          <div class="metadata-group">
            <p class="meta-label">Profiles</p>
            <p class="person-links">
              {% if member.scholarUrl %}<a href="{{ member.scholarUrl }}">Google Scholar</a>{% endif %}
              {% if member.orcidUrl %}<a href="{{ member.orcidUrl }}">ORCID</a>{% endif %}
            </p>
          </div>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>
