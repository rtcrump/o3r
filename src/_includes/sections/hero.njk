<section class="hero section-panel">
  <div class="hero-copy">
    <p class="eyebrow"><span>{{ site.shortName }}</span> {{ site.affiliation }}</p>
    <h1>{{ site.labName }}</h1>
    <p class="hero-tagline">{{ site.tagline }}</p>
    <p class="hero-summary">{{ site.heroSummary }}</p>
    <div class="hero-actions">
      <a class="button button-primary" href="#join">Work with us</a>
      <a class="button button-secondary" href="#projects">Explore projects</a>
    </div>
  </div>
</section>
