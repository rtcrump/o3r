<section class="section-band" id="projects">
  <div class="section-heading">
    <p class="eyebrow">Projects</p>
    <h2>Active work</h2>
    <p>Our projects include manuscripts, data infrastructure, and applied research grounded in clinical care.</p>
  </div>
  <div class="project-list">
    {% for project in projects %}
      <article class="project-row" id="project-{{ project.id }}">
        <div class="project-main">
          <div class="project-title-line">
            <h3>{{ project.title }}</h3>
            <span class="status-pill status-{{ project.status | statusClass }}">{{ project.status }}</span>
          </div>
          <p>{{ project.summary }}</p>
          {% if project.tags and project.tags.length %}
            <ul class="chip-list tag-list" aria-label="Project topics">
              {% for tag in project.tags %}
                <li class="keyword-chip">{{ tag }}</li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if project.publications and project.publications.length %}
            <div class="metadata-group">
              <p class="meta-label">Related publications</p>
              <ul class="publication-links">
                {% for publication in project.publications %}
                  <li><a href="{{ publication.url }}">{{ publication.label }}</a></li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        </div>
        <div class="project-link">
          {% if project.link %}
            <a href="{{ project.link }}">View artifact</a>
          {% else %}
            <span>No public link yet</span>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>
